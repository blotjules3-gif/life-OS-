# LifeOS Agent Backend — configuration template
# Copy to .env and fill in values. NEVER commit .env to git.

# App
APP_NAME="LifeOS Agent"
DEBUG=false
SECRET_KEY=change_this_to_random_64_char_string
INTERNAL_API_KEY=change_this_to_random_32_char_string

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://lifeos:password@localhost:5432/lifeos_agent

# LLM — Mistral AI
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-large-latest
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=30

# Redis
REDIS_URL=redis://localhost:6379/0

# Apple Push Notifications (APNs)
APNS_KEY_ID=your_apns_key_id
APNS_TEAM_ID=your_apple_team_id
APNS_BUNDLE_ID=com.yourcompany.lifeos
APNS_PRIVATE_KEY_PATH=/secrets/apns_key.p8
APNS_USE_SANDBOX=true

# CORS — list iOS app origins if using web views
ALLOWED_ORIGINS=*
